{
  "name": "news",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm migrate:local && vite",
    "dev:e2e": "pnpm migrate:local:e2e && CLOUDFLARE_ENV=e2e vite --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "wrangler:login": "wrangler login",
    "cf-typegen": "wrangler types",
    "check": "pnpm cf-typegen && pnpm check:format && pnpm check:lint && pnpm check:ts && pnpm check:knip && pnpm check:dup && pnpm check:tf && pnpm test:unit",
    "check:format": "prettier --check .",
    "check:lint": "eslint .",
    "check:ts": "pnpm cf-typegen && tsc -p tsconfig.app.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.e2e.json",
    "check:knip": "knip",
    "check:dup": "jscpd",
    "fix": "prettier --write . && eslint . --fix",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:setup": "pnpm install && playwright install chromium",
    "playwright:install": "playwright install --with-deps chromium",
    "prepare": "husky",
    "worktree": "bash scripts/worktree.sh",
    "merge": "bash scripts/worktree-merge.sh",
    "migrate:gen": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:local:e2e": "wrangler d1 migrations apply DB --local --env e2e",
    "tf:init": "terraform -chdir=iac init -backend=false -input=false",
    "check:tf": "terraform -chdir=iac fmt -check && terraform -chdir=iac validate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "arctic": "^3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "posthog-js": "^1.396.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "knip": "^6.23.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
