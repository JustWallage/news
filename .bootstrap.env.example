# Copy to .bootstrap.env (gitignored), fill in, then run scripts/bootstrap.sh.
# Where each value comes from is documented in docs/BOOTSTRAP.md.

CLOUDFLARE_ACCOUNT_ID=
# Custom API token. Scopes: Workers Scripts:Edit, D1:Edit, Workers R2 Storage:Edit,
# Access (Apps and Policies):Edit, Access (Organizations, IdP, Groups):Edit,
# Workers AI:Read, and (zone justwallage.nl) Workers Routes:Edit + Zone:Read
# — the last two let wrangler attach the news.justwallage.nl custom domain.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# Reuse the existing stelplaats/Access Google OAuth client (same team-domain callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Random string gating the e2e auth path on deployed e2e workers.
# Generate with: openssl rand -hex 32
TEST_AUTH_TOKEN=
# Full workers.dev host suffix, e.g. "justwallage.workers.dev" (Workers & Pages
# → your subdomain). Worker URLs are https://<worker-name>.<this>.
WORKERS_DEV_SUBDOMAIN=
# Zone id of justwallage.nl (dashboard → justwallage.nl → Overview → Zone ID).
# Activates news.justwallage.nl + the Access app on the first deploy.
CUSTOM_DOMAIN_ZONE_ID=

# --- Telegram bot (optional) -------------------------------------------------
# Leave blank to skip the bot. When set, bootstrap pushes them as GHA secrets and
# deploy.yml installs them onto the production worker. See docs/BOOTSTRAP.md §8.
# HTTP API token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Random string shared with Telegram's setWebhook (openssl rand -hex 32).
TELEGRAM_WEBHOOK_SECRET=
